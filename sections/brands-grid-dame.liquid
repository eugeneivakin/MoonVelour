<div class="brands-grid-wrapper" id="brands-grid-{{ section.id }}">
  <div class="brands-grid-inner">
    {% if section.settings.section_title != blank %}
      <div class="brands-grid-header">
        <h1 class="brands-grid-title">{{ section.settings.section_title }}</h1>
        {% if section.settings.section_subtitle != blank %}
          <p class="brands-grid-subtitle">{{ section.settings.section_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="brands-grid">
      {% for block in section.blocks %}
        {% assign col = collections[block.settings.collection] %}
        {% if col != blank %}
          <a href="{{ col.url }}" class="brand-card" {{ block.shopify_attributes }}>
            <div class="brand-card-image">
              {% if col.image %}
                {{ col.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'brand-img' }}
              {% elsif col.products.first.featured_image %}
                {{ col.products.first.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'brand-img' }}
              {% else %}
                <div class="brand-placeholder">
                  <span>{{ col.title }}</span>
                </div>
              {% endif %}
              <div class="brand-card-overlay">
                <span class="brand-view-btn">SHOP NOW &rarr;</span>
              </div>
            </div>
            <div class="brand-card-info">
              <h3 class="brand-card-name">{{ col.title }}</h3>
              <span class="brand-card-count">{{ col.products_count }} {{ col.products_count | pluralize: 'product', 'products' }}</span>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<style>
  #brands-grid-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#faf8f9' }};
  }

  #brands-grid-{{ section.id }} .brands-grid-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 40px {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    #brands-grid-{{ section.id }} .brands-grid-inner {
      padding: 40px 20px;
    }
  }

  #brands-grid-{{ section.id }} .brands-grid-header {
    text-align: center;
    margin-bottom: 48px;
  }

  #brands-grid-{{ section.id }} .brands-grid-title {
    font-size: 42px;
    color: {{ section.settings.title_color | default: '#6B2D5B' }};
    font-weight: 400;
    margin: 0 0 12px;
    letter-spacing: -0.5px;
  }

  @media screen and (max-width: 749px) {
    #brands-grid-{{ section.id }} .brands-grid-title {
      font-size: 30px;
    }
  }

  #brands-grid-{{ section.id }} .brands-grid-subtitle {
    font-size: 16px;
    color: #888;
    margin: 0;
    font-weight: 400;
  }

  #brands-grid-{{ section.id }} .brands-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop | default: 4 }}, 1fr);
    gap: 20px;
  }

  @media screen and (max-width: 989px) {
    #brands-grid-{{ section.id }} .brands-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    #brands-grid-{{ section.id }} .brands-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
  }

  #brands-grid-{{ section.id }} .brand-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    transition: all 0.3s ease;
  }

  #brands-grid-{{ section.id }} .brand-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(107,45,91,0.1);
    border-color: rgba(107,45,91,0.15);
  }

  #brands-grid-{{ section.id }} .brand-card-image {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f8f6f7;
  }

  #brands-grid-{{ section.id }} .brand-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  #brands-grid-{{ section.id }} .brand-card:hover .brand-img {
    transform: scale(1.05);
  }

  #brands-grid-{{ section.id }} .brand-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, #6B2D5B, #7850ca);
    padding: 20px;
  }

  #brands-grid-{{ section.id }} .brand-placeholder span {
    font-size: 22px;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    text-transform: uppercase;
    letter-spacing: 2px;
    text-align: center;
    line-height: 1.3;
  }

  @media screen and (max-width: 749px) {
    #brands-grid-{{ section.id }} .brand-placeholder span {
      font-size: 16px;
      letter-spacing: 1.5px;
    }
  }

  #brands-grid-{{ section.id }} .brand-card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }

  #brands-grid-{{ section.id }} .brand-card:hover .brand-card-overlay {
    background: rgba(107,45,91,0.25);
  }

  #brands-grid-{{ section.id }} .brand-view-btn {
    padding: 10px 24px;
    background: #fff;
    color: #6B2D5B;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.3s ease;
  }

  #brands-grid-{{ section.id }} .brand-card:hover .brand-view-btn {
    opacity: 1;
    transform: translateY(0);
  }

  #brands-grid-{{ section.id }} .brand-card-info {
    padding: 16px;
    text-align: center;
    border-top: 1px solid rgba(0,0,0,0.04);
  }

  @media screen and (max-width: 749px) {
    #brands-grid-{{ section.id }} .brand-card-info {
      padding: 12px;
    }
  }

  #brands-grid-{{ section.id }} .brand-card-name {
    font-size: 15px;
    color: #2a2a2a;
    font-weight: 600;
    margin: 0 0 2px;
  }

  @media screen and (max-width: 749px) {
    #brands-grid-{{ section.id }} .brand-card-name {
      font-size: 13px;
    }
  }

  #brands-grid-{{ section.id }} .brand-card-count {
    font-size: 12px;
    color: #aaa;
    font-weight: 400;
  }
</style>

{% schema %}
{
  "name": "Brands Grid",
  "class": "section-brands-grid",
  "settings": [
    { "type": "text", "id": "section_title", "label": "Section Title", "default": "Our Brands" },
    { "type": "richtext", "id": "section_subtitle", "label": "Section Subtitle" },
    { "type": "color", "id": "title_color", "label": "Title Color", "default": "#6B2D5B" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#faf8f9" },
    { "type": "range", "id": "columns_desktop", "min": 2, "max": 6, "step": 1, "label": "Columns Desktop", "default": 4 },
    { "type": "range", "id": "columns_mobile", "min": 1, "max": 3, "step": 1, "label": "Columns Mobile", "default": 2 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top", "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 60 }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brands Grid"
    }
  ]
}
{% endschema %}