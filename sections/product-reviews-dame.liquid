<div class="mv-reviews-section" id="reviews-{{ section.id }}">
  <div class="mv-reviews-inner page-width">
    <div class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}"></div>
    
    <div class="mv-reviews-fallback" id="mv-reviews-fallback-{{ section.id }}">
      <h3 class="mv-reviews-title">Customer Reviews</h3>
      <p class="mv-reviews-empty">Be the first to share your experience</p>
      <button class="mv-write-review-btn" onclick="
        var widget = this.closest('.mv-reviews-section').querySelector('.jdgm-review-widget');
        if (widget) {
          var form = widget.querySelector('.jdgm-form');
          if (form) { form.style.display = 'block'; }
          else { 
            var openBtn = widget.querySelector('.jdgm-write-rev-btn');
            if (openBtn) openBtn.click();
          }
        }
      ">Write a Review</button>
    </div>
  </div>
</div>

<style>
  #reviews-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    border-top: 1px solid #eee;
  }
  #reviews-{{ section.id }} .mv-reviews-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  /* Hide fallback when Judge.me renders content */
  #reviews-{{ section.id }} .jdgm-review-widget:not(:empty) ~ .mv-reviews-fallback {
    display: none;
  }
  #reviews-{{ section.id }} .mv-reviews-fallback {
    text-align: center;
    padding: 32px 0;
  }
  #reviews-{{ section.id }} .mv-reviews-title {
    font-size: 22px;
    color: #6B2D5B;
    font-weight: 500;
    margin: 0 0 8px;
  }
  #reviews-{{ section.id }} .mv-reviews-empty {
    font-size: 14px;
    color: #999;
    margin: 0 0 20px;
  }
  #reviews-{{ section.id }} .mv-write-review-btn {
    display: inline-block;
    padding: 12px 32px;
    background: #7850ca;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: background 0.25s ease;
  }
  #reviews-{{ section.id }} .mv-write-review-btn:hover {
    background: #6640b0;
  }
</style>

{% schema %}
{
  "name": "Product Reviews",
  "templates": ["product"],
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 32
    }
  ],
  "presets": [{ "name": "Product Reviews" }]
}
{% endschema %}