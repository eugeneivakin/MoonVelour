{%- style -%}
  .dame-related { padding: 40px 0 60px; }
  .dame-related__title { font-family: var(--font-heading-family); font-size: 32px; font-weight: 500; color: #624c63; text-align: center; margin-bottom: 30px; }
  .dame-related__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  @media (max-width: 989px) { .dame-related__grid { grid-template-columns: repeat(2, 1fr); gap: 15px; } }
  @media (max-width: 749px) { .dame-related__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; } .dame-related__title { font-size: 24px; } }
  .dame-rel-card { background: #fff; border-radius: 15px; overflow: hidden; display: flex; flex-direction: column; }
  .dame-rel-img-link { display: block; overflow: hidden; border-radius: 15px 15px 0 0; }
  .dame-rel-img-wrap { width: 100%; aspect-ratio: 3/4; overflow: hidden; position: relative; background: #f5f5f5; }
  .dame-rel-img { width: 100%; height: 100%; object-fit: cover; transition: opacity 0.4s ease, transform 0.3s; }
  .dame-rel-img--hover { position: absolute; top: 0; left: 0; opacity: 0; }
  .dame-rel-img-link:hover .dame-rel-img--primary { opacity: 0; }
  .dame-rel-img-link:hover .dame-rel-img--hover { opacity: 1; }
  .dame-rel-img-link:hover .dame-rel-img { transform: scale(1.03); }
  .dame-rel-info { padding: 15px; display: flex; flex-direction: column; flex-grow: 1; }
  .dame-rel-rating { margin-bottom: 6px; }
  .dame-rel-name { font-family: var(--font-heading-family); font-size: 16px; font-weight: 500; margin: 0 0 4px; line-height: 1.3; }
  .dame-rel-name a { color: inherit; text-decoration: none; }
  .dame-rel-price { font-family: var(--font-body-family); font-size: 14px; color: #333; margin-bottom: 10px; }
  .dame-rel-price s { color: #999; margin-right: 6px; }
  .dame-rel-price .sale { color: #7850ca; font-weight: 600; }
  .dame-rel-btn { display: block; width: 100%; padding: 10px; border: none; border-radius: 8px; background: #7850ca; color: #fff; font-family: var(--font-body-family); font-size: 13px; font-weight: 400; cursor: pointer; text-align: center; margin-top: auto; transition: background 0.2s; letter-spacing: 0.5px; }
  .dame-rel-btn:hover { background: #624c63; }
  .dame-rel-btn:disabled { background: #b8b3e8; cursor: not-allowed; }
  .dame-rel-disc { position: absolute; top: 10px; right: 10px; background: #ff4444; color: #fff; font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 6px; z-index: 2; }
{%- endstyle -%}

<div class="page-width dame-related">
  <product-recommendations
    class="related-products{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&limit={{ section.settings.products_to_show }}"
    data-section-id="{{ section.id }}"
    data-product-id="{{ product.id }}"
  >
    {% if recommendations.performed and recommendations.products_count > 0 %}
      <h2 class="dame-related__title">{{ section.settings.heading }}</h2>
      <div class="dame-related__grid">
        {% for recommendation in recommendations.products %}
          <div class="dame-rel-card">
            <a href="{{ recommendation.url }}" class="dame-rel-img-link{% if recommendation.images[1] %} dame-rel-has-swap{% endif %}">
              <div class="dame-rel-img-wrap">
                {% if recommendation.featured_image %}
                  {{ recommendation.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'dame-rel-img dame-rel-img--primary' }}
                  {% if recommendation.images[1] %}
                    {{ recommendation.images[1] | image_url: width: 600 | image_tag: loading: 'lazy', class: 'dame-rel-img dame-rel-img--hover' }}
                  {% endif %}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'dame-rel-img' }}
                {% endif %}
                {% if recommendation.compare_at_price > recommendation.price %}
                  {% assign disc = recommendation.compare_at_price | minus: recommendation.price | times: 100 | divided_by: recommendation.compare_at_price %}
                  <span class="dame-rel-disc">-{{ disc }}%</span>
                {% endif %}
              </div>
            </a>
            <div class="dame-rel-info">
              <div class="dame-rel-rating"><span class="jdgm-widget jdgm-preview-badge" data-id="{{ recommendation.id }}"></span></div>
              <h3 class="dame-rel-name"><a href="{{ recommendation.url }}">{{ recommendation.title }}</a></h3>
              <div class="dame-rel-price">
                {% if recommendation.compare_at_price > recommendation.price %}
                  <s>{{ recommendation.compare_at_price | money }}</s>
                  <span class="sale">{{ recommendation.price | money }}</span>
                {% else %}
                  {{ recommendation.price | money }}
                {% endif %}
              </div>
              {% if recommendation.available %}
                <button class="dame-rel-btn dame-btn-add-to-cart"
                        data-variant-id="{{ recommendation.first_available_variant.id }}"
                        data-product-url="{{ recommendation.url }}"
                        data-variant-count="{{ recommendation.variants.size }}">
                  ADD TO CART | {{ recommendation.price | money }}
                </button>
              {% else %}
                <button class="dame-rel-btn" disabled>SOLD OUT</button>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </product-recommendations>
</div>

<script>
(function(){
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.dame-related .dame-btn-add-to-cart');
    if (!btn || btn.disabled) return;
    e.preventDefault();
    var variantId = btn.dataset.variantId;
    var variantCount = parseInt(btn.dataset.variantCount || '1');
    if (!variantId || variantCount > 1) { window.location.href = btn.dataset.productUrl; return; }
    var origHTML = btn.innerHTML;
    btn.innerHTML = '<svg class="dame-spinner" width="18" height="18" viewBox="0 0 24 24"><style>.dame-spinner{animation:dame-spin .6s linear infinite}@keyframes dame-spin{to{transform:rotate(360deg)}}</style><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-dasharray="50 20" stroke-linecap="round"/></svg>';
    btn.disabled = true;
    btn.style.display = 'flex'; btn.style.alignItems = 'center'; btn.style.justifyContent = 'center';
    fetch('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: [{ id: parseInt(variantId), quantity: 1 }] }) })
    .then(function(r) { return r.json(); })
    .then(function() { return fetch('/?sections=cart-drawer,cart-icon-bubble'); })
    .then(function(r) { return r.json(); })
    .then(function(sections) {
      var d = document.getElementById('CartDrawer');
      if (d) { var p = new DOMParser().parseFromString(sections['cart-drawer'], 'text/html'); var n = p.querySelector('#CartDrawer'); if (n) d.innerHTML = n.innerHTML; }
      var b = document.getElementById('cart-icon-bubble');
      if (b) { var p2 = new DOMParser().parseFromString(sections['cart-icon-bubble'], 'text/html'); var n2 = p2.querySelector('.shopify-section'); if (n2) b.innerHTML = n2.innerHTML; }
      var cd = document.querySelector('cart-drawer');
      if (cd) { cd.classList.add('animate', 'active'); document.body.classList.add('overflow-hidden'); var ov = cd.querySelector('#CartDrawer-Overlay'); if (ov) ov.addEventListener('click', function() { cd.close(); }); }
      btn.innerHTML = origHTML; btn.disabled = false; btn.style.display = '';
    })
    .catch(function() { btn.innerHTML = 'ERROR'; setTimeout(function() { btn.innerHTML = origHTML; btn.disabled = false; btn.style.display = ''; }, 1500); });
  });
})();
</script>

{% schema %}
{
  "name": "t:sections.related-products.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.related-products.settings.paragraph__1.content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "You may also like",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4,
      "label": "t:sections.related-products.settings.products_to_show.label"
    }
  ]
}
{% endschema %}
